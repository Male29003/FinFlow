{
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
        {
            "files": "*.html",
            "options": {
                "parser": "angular"
            }
        }
    ],
    "tabWidth": 3,
    "useTabs": false,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "always"
}
